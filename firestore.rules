rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Temporary permissive rules for stabilizing the app flow.
    // Any signed-in user can create/read/update app room data, invites, and
    // shared-space subcollections. Lock this down again after registration,
    // invite creation, and invite acceptance are confirmed working end to end.

    match /users/{userId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /sharedSpaces/{spaceId} {
      allow read, create, update: if signedIn();
      allow delete: if false;

      match /members/{memberId} {
        allow read, create, update, delete: if signedIn();
      }

      match /products/{productId} {
        allow read, create, update, delete: if signedIn();
      }

      match /shoppingItems/{itemId} {
        allow read, create, update, delete: if signedIn();
      }

      match /purchaseRecords/{recordId} {
        allow read, create, update, delete: if signedIn();
      }
    }

    match /invites/{inviteId} {
      allow read, create, update, delete: if signedIn();
    }
  }
}
